# ─────────────────────────────────────────────
#   FDL CHEMICALS — ENVIRONMENT CONFIGURATION
# ─────────────────────────────────────────────
#   Copy this file to .env and fill in your values
#   NEVER commit .env to version control
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# ─── ADMIN CONFIGURATION ─────────────────────────
# Used to protect the admin panel (/admin).
# Login token
ADMIN_TOKEN=your-admin-token-here

# ─── EMAIL CONFIGURATION ─────────────────────
# The address that receives contact form submissions
CONTACT_RECEIVER_EMAIL=contact@fdl-chemicals.ma

# The address used in the email "from"
CONTACT_SENDER_EMAIL=noreply@fdl-chemicals.ma

# SMTP credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# ─── SITE SETTINGS ───────────────────────────
SITE_NAME=FDL Chemicals
SITE_URL=http://localhost:3000
DEFAULT_LANG=fr

# ─── RATE LIMITING ───────────────────────────
# Max contact form submissions per IP per 15 minutes
RATE_LIMIT_MAX=5
