# ─────────────────────────────────────────────
#   FDL CHEMICALS — ENVIRONMENT CONFIGURATION
# ─────────────────────────────────────────────
#   Copy this file to .env and fill in your values
#   NEVER commit .env to version control
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# ─── EMAIL CONFIGURATION ─────────────────────
# The address that receives contact form submissions
CONTACT_RECEIVER_EMAIL=mahmoudaymane@icloud.com

# The address used to send emails (your SMTP "from" address)
CONTACT_SENDER_EMAIL=noreply@fdl-chemicals.ma

# SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here

# ─── SITE SETTINGS ───────────────────────────
SITE_NAME=FDL Chemicals
SITE_URL=http://localhost:3000
DEFAULT_LANG=fr

# ─── RATE LIMITING ───────────────────────────
# Max contact form submissions per IP per 15 minutes
RATE_LIMIT_MAX=5
