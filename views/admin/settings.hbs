<section style="min-height:100vh;padding:28px;">
  <div style="max-width:980px;margin:0 auto;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:18px;">
      <div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:10px;">
          Admin Settings
        </div>
        <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:44px;line-height:1;margin:0;">
          Website details
        </h1>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#4a5e4a;margin-top:10px;line-height:1.6;">
          Edit the contact info + footer shown on the homepage.
        </div>
      </div>

      <form method="POST" action="/admin/logout">
        <button type="submit" style="border:2px solid #000;background:#fff;padding:10px 14px;font-weight:900;font-family:'Barlow Condensed',sans-serif;text-transform:uppercase;letter-spacing:.04em;box-shadow:4px 4px 0 #000;cursor:pointer;">
          Logout
        </button>
      </form>
    </div>

    {{#if (ne (lookup query 'updated') '1')}}
    {{/if}}

    {{#if updated}}
      <div style="border:2px solid #000;background:#7aff4f;padding:12px;margin-bottom:16px;font-family:'IBM Plex Mono',monospace;font-size:12px;">
        Saved ✓
      </div>
    {{/if}}

    {{#if error}}
      <div style="border:2px solid #000;background:#ffd6d6;padding:12px;margin-bottom:16px;font-family:'IBM Plex Mono',monospace;font-size:12px;">
        {{error}}
      </div>
    {{/if}}

    <form method="POST" action="/admin">
      <div style="border:2px solid #000;background:#e8f0e8;padding:18px;box-shadow:6px 6px 0 #000;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#2e4a2e;margin-bottom:12px;">
          Contact details
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div style="grid-column:1 / -1;">
            <label style="display:block;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:8px;">
              Address
            </label>
            <input
              name="contact_address_value"
              type="text"
              required
              value="{{settings.contact.address_value}}"
              style="width:100%;border:2px solid #000;background:#fff;padding:12px;font-family:inherit;font-size:16px;outline:none;"
            />
          </div>

          <div>
            <label style="display:block;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:8px;">
              Email
            </label>
            <input
              name="contact_email_value"
              type="email"
              required
              value="{{settings.contact.email_value}}"
              style="width:100%;border:2px solid #000;background:#fff;padding:12px;font-family:inherit;font-size:16px;outline:none;"
            />
          </div>

          <div>
            <label style="display:block;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:8px;">
              Phone
            </label>
            <input
              name="contact_phone_value"
              type="text"
              required
              value="{{settings.contact.phone_value}}"
              style="width:100%;border:2px solid #000;background:#fff;padding:12px;font-family:inherit;font-size:16px;outline:none;"
            />
          </div>

          <div style="grid-column:1 / -1;">
            <label style="display:block;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:8px;">
              Business hours
            </label>

            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
              <div style="grid-column:1 / -1;">
                <label style="display:block;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:8px;">
                  Days
                </label>
                <input
                  name="contact_hours_day_value"
                  type="text"
                  required
                  value="{{settings.contact.hours_edit_day_value}}"
                  placeholder="Mon–Fri"
                  style="width:100%;border:2px solid #000;background:#fff;padding:12px;font-family:inherit;font-size:16px;outline:none;"
                />
              </div>

              <div>
                <label style="display:block;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:8px;">
                  Start
                </label>
                <input
                  name="contact_hours_start_time_value"
                  type="time"
                  required
                  value="{{settings.contact.hours_edit_start_time_value}}"
                  style="width:100%;border:2px solid #000;background:#fff;padding:12px;font-family:inherit;font-size:16px;outline:none;"
                />
              </div>

              <div>
                <label style="display:block;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:8px;">
                  End
                </label>
                <input
                  name="contact_hours_end_time_value"
                  type="time"
                  required
                  value="{{settings.contact.hours_edit_end_time_value}}"
                  style="width:100%;border:2px solid #000;background:#fff;padding:12px;font-family:inherit;font-size:16px;outline:none;"
                />
              </div>
            </div>
          </div>
        </div>

        <div style="height:18px;"></div>

        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#2e4a2e;margin-bottom:12px;">
          Footer
        </div>

        <label style="display:block;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#2e4a2e;margin-bottom:8px;">
          Footer copy
        </label>
        <input
          name="footer_copy"
          type="text"
          required
          value="{{settings.footer.copy}}"
          style="width:100%;border:2px solid #000;background:#fff;padding:12px;font-family:inherit;font-size:16px;outline:none;"
        />

        <div style="height:16px;"></div>

        <button type="submit" style="width:100%;border:2px solid #000;background:#7aff4f;color:#080a08;padding:14px;font-weight:900;font-family:'Barlow Condensed',sans-serif;text-transform:uppercase;letter-spacing:.04em;box-shadow:4px 4px 0 #000;cursor:pointer;">
          Save changes →
        </button>
      </div>
    </form>

    <div style="margin-top:14px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:#4a5e4a;line-height:1.7;">
      Changes are stored in <code style="background:#fff;border:1px dashed #2e4a2e;padding:2px 6px;">data/site-settings.json</code>.
      They apply to the homepage immediately after saving.
    </div>
  </div>
</section>
